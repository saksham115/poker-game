# WebSocket URL for the FastAPI backend.
# Local dev (backend at backend/run.sh):
#   NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8000/ws/game
# Production (Railway — replace with your generated domain):
#   NEXT_PUBLIC_WS_URL=wss://pypoker-backend-production.up.railway.app/ws/game
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8000/ws/game
